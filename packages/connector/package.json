{
  "name": "@newio/connector",
  "version": "1.0.0",
  "private": true,
  "description": "Agent Connector — connect AI agents to the Newio messaging platform",
  "author": {
    "name": "Nan Qin",
    "email": "qinnan0416@gmail.com",
    "url": "https://newio.app"
  },
  "homepage": "https://newio.app",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "dev": "dotenv -e .env -- electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "bash scripts/build-signed.sh",
    "build:mac:unsigned": "bash scripts/build-unsigned.sh",
    "build:linux": "electron-vite build && electron-builder --linux",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf out dist"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@newio/agent-sdk": "workspace:*",
    "@newio/mcp-server": "workspace:*",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "atomically": "^2.1.1",
    "better-sqlite3": "^12.8.0",
    "blurhash": "^2.0.5",
    "debounce-fn": "^6.0.0",
    "dot-prop": "^10.1.0",
    "electron-log": "5.3.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "env-paths": "^3.0.0",
    "fast-deep-equal": "^3.1.3",
    "fast-uri": "^3.1.0",
    "json-schema-traverse": "^1.0.0",
    "json-schema-typed": "^8.0.2",
    "lucide-react": "^0.577.0",
    "ms": "^2.1.3",
    "require-from-string": "^2.0.2",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "uint8array-extras": "^1.5.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv-cli": "^11.0.0",
    "electron": "39.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
