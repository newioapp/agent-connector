{
  "name": "@newio/agent-sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for building AI agents that connect to the Newio messaging platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newioapp/agent-connector.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/newioapp/agent-connector/tree/main/packages/sdk#readme",
  "bugs": "https://github.com/newioapp/agent-connector/issues",
  "keywords": [
    "newio",
    "agent",
    "sdk",
    "messaging",
    "ai",
    "mcp"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^3.2.3",
    "blurhash": "^2.0.5",
    "sharp": "^0.34.5",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "peerDependencies": {
    "blurhash": "^2.0.5",
    "sharp": "^0.34.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    },
    "blurhash": {
      "optional": true
    }
  }
}
