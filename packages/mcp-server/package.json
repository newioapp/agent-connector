{
  "name": "@newio/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the Newio messaging platform — developer-friendly tools for AI agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newioapp/agent-connector.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/newioapp/agent-connector/tree/main/packages/mcp-server#readme",
  "bugs": "https://github.com/newioapp/agent-connector/issues",
  "keywords": [
    "newio",
    "mcp",
    "agent",
    "messaging",
    "ai",
    "model-context-protocol"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@newio/sdk": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
